# 应用监听端口；Compose 同时将该端口映射到宿主机。
PORT=5173

# 数据库配置。Docker Compose 会把 DB_HOST/DB_PORT 改为容器内部地址，
# 以下 host/port 主要供“本机 Node.js + Docker MySQL”的脚本部署方式使用。
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=zongce
DB_PASSWORD=zongce123
DB_NAME=bnuai_zongce

# MySQL root 密码仅供数据库容器首次初始化使用。
MYSQL_ROOT_PASSWORD=root123

# AI 材料审核。请将真实密钥只写进本机 .env，绝不能写进源码或提交到 Git。
AI_API_KEY=
AI_API_BASE_URL=https://ws-uwiff5b8ww2vs5zv.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-vl-max

